# Copia este archivo a .env y ajusta las rutas si hace falta.
# No subas .env ni credentials.json a Git.

# Ruta al JSON de la Service Account de Google (opcional).
# Si no lo defines, se usa credentials.json en la carpeta del proyecto.
# GOOGLE_CREDENTIALS_PATH=./credentials.json
# GOOGLE_CREDENTIALS_PATH=/ruta/completa/a/tu-credenciales.json

# Puerto del servidor (opcional, por defecto 8000)
# PORT=8000
